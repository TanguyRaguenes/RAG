      "connect": { "host": "localhost", "port": 5682 },
      "pathMappings": [
        { "localRoot": "${workspaceFolder}/rag_ihm", "remoteRoot": "/app" }
      ]
    },
    {
      "name": "Attach rag_retriever",
      "type": "debugpy",
      "request": "attach",
      "connect": { "host": "localhost", "port": 5678 },
      "pathMappings": [
        { "localRoot": "${workspaceFolder}/rag_retriever", "remoteRoot": "/app" }
      ]
    },
    {
      "name": "Attach rag_mcp",
      "type": "debugpy",
      "request": "attach",
      "connect": { "host": "localhost", "port": 5683 },
      "pathMappings": [
        { "localRoot": "${workspaceFolder}/rag_mcp", "remoteRoot": "/app" }
      ]
    }
  ]
}
