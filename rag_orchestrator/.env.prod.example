# Copy this file to rag_orchestrator/.env on the production server.
# Never commit real secrets.

# Optional if provider=api is used. Leave empty only if the code supports local-only usage.
OPEN_API_KEY=CHANGE_ME_OPENAI_OR_COMPATIBLE_API_KEY

# OIDC issuer must match the issuer claim generated by Pocket ID.
OIDC_ISSUER=https://auth.example.com
OIDC_JWKS_URI=http://pocket-id:1411/.well-known/jwks.json
OIDC_USERINFO_URL=http://pocket-id:1411/api/oidc/userinfo
OIDC_ALLOWED_AUDIENCES=CHANGE_ME_IHM_CLIENT_ID,CHANGE_ME_MCP_CLIENT_ID

# If the password contains special URL characters, URL-encode it in DATABASE_URL.
DATABASE_URL=postgresql://rag_user:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/rag_usage
USER_HASH_SECRET=CHANGE_ME_RANDOM_HEX_SECRET

DEFAULT_USER_MONTHLY_TOKEN_QUOTA=100000
RAG_USAGE_ADMIN_GROUPS=rag_admin
