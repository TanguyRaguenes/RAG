# Docker Compose production variables.
# Copy this file to .env on the production server, then replace CHANGE_ME values.

# Docker Hub namespace used by custom RAG images.
DOCKERHUB_NAMESPACE=tanguyraguenes

# PostgreSQL
POSTGRES_DB=rag_usage
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# Caddy public hosts. Use real DNS names in production.
RAG_IHM_HOST=rag.example.com
RAG_MCP_HOST=mcp.example.com
RAG_AUTH_HOST=auth.example.com
RAG_GRAFANA_HOST=grafana.example.com

# Browser-facing OIDC URLs used by rag_ihm.
RAG_IHM_OIDC_AUTHORIZE_URL=https://auth.example.com/authorize
RAG_IHM_OIDC_TOKEN_URL=https://auth.example.com/api/oidc/token
RAG_IHM_OIDC_REDIRECT_URI=https://rag.example.com

# Host paths mounted in containers.
RAG_WIKIS_PATH=/opt/rag/wikis
RAG_EVALUATOR_DATASET_PATH=/opt/rag/rag_evaluator/dataset.json
